<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Taskmate" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="android:windowBackground">@color/surface</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceContainer">@color/surface_container</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOutline">@color/outline</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="colorError">@color/error</item>
    </style>

    <style name="Theme.Taskmate" parent="Base.Theme.Taskmate" />

    <style name="Theme.Taskmate.Splash" parent="Theme.SplashScreen">
        <!-- Set the background to match your loading screen -->
        <item name="windowSplashScreenBackground">@color/primary</item>

        <!-- Use a transparent icon to "remove" the default Android head -->
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>

        <item name="postSplashScreenTheme">@style/Theme.Taskmate</item>

        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>
</resources>