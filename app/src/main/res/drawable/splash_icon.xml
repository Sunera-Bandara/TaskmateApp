<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- White rounded background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
            <corners android:radius="24dp" />
            <size android:width="108dp" android:height="108dp"/>
        </shape>
    </item>
    <!-- Blue inner box -->
    <item android:top="20dp" android:bottom="20dp" android:left="20dp" android:right="20dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/primary" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Checkmark icon -->
    <item android:top="36dp" android:bottom="36dp" android:left="36dp" android:right="36dp">
        <bitmap android:src="@drawable/ic_check" android:tint="@color/white"/>
    </item>
</layer-list>